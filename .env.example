# .env.example
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# このファイルを .env という名前でコピーして、値を入力してください。
# .env ファイルは .gitignore に含まれているので Git には上がりません。
# ローカル（Windows）で実行するときだけ必要です。
# GitHub Actions では Secrets に登録してください（README参照）。
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 通知を受け取るメールアドレス（どのメールでもOK）
NOTIFY_EMAIL=your@email.com

# 送信元のGmailアドレス
GMAIL_FROM=your@gmail.com

# Gmailアプリパスワード（通常のパスワードとは別物）
# 取得方法: Googleアカウント → セキュリティ → 2段階認証を有効化
#           → アプリパスワード → 「メール」「Windows」で生成
# 形式: xxxx xxxx xxxx xxxx（スペース込みでそのまま貼り付けOK）
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
